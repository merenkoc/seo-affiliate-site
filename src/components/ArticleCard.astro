---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  category: string;
  tags: string[];
}

const { title, description, pubDate, slug, category, tags } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group bg-white border border-gray-100 rounded-2xl p-6 hover:shadow-md hover:border-brand-500/30 transition-all duration-200">
  <div class="flex items-center gap-2 mb-3">
    <span class="text-xs font-semibold text-brand-600 bg-brand-50 px-2.5 py-0.5 rounded-full uppercase tracking-wide">
      {category}
    </span>
    <time class="text-xs text-gray-400" datetime={pubDate.toISOString()}>
      {formattedDate}
    </time>
  </div>

  <h2 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-brand-600 transition-colors leading-snug">
    <a href={`/blog/${slug}`} class="stretched-link">{title}</a>
  </h2>

  <p class="text-sm text-gray-500 leading-relaxed line-clamp-3 mb-4">
    {description}
  </p>

  <div class="flex flex-wrap gap-1.5">
    {tags.slice(0, 3).map(tag => (
      <span class="text-xs text-gray-400 bg-gray-50 border border-gray-100 px-2 py-0.5 rounded-md">
        #{tag}
      </span>
    ))}
  </div>
</article>
