---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  category: string;
  tags: string[];
  affiliate_disclosure: boolean;
  seo?: {
    metaTitle?: string;
    metaDescription?: string;
    focusKeyword?: string;
  };
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author,
  category,
  tags,
  affiliate_disclosure,
  seo,
} = Astro.props;

const metaTitle = seo?.metaTitle ?? `${title} | BestPicks`;
const metaDescription = seo?.metaDescription ?? description;
const siteBase = Astro.site ?? new URL('https://seo-affiliate-site.vercel.app');
const canonicalURL = new URL(Astro.url.pathname, siteBase);

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{metaTitle}</title>
  <meta name="description" content={metaDescription} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={metaTitle} />
  <meta property="og:description" content={metaDescription} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="article" />
  <meta property="article:published_time" content={pubDate.toISOString()} />
  {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={metaTitle} />
  <meta name="twitter:description" content={metaDescription} />

  <!-- Schema.org Article -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "datePublished": pubDate.toISOString(),
    "dateModified": (updatedDate ?? pubDate).toISOString(),
    "author": { "@type": "Person", "name": author },
    "publisher": {
      "@type": "Organization",
      "name": "BestPicks",
      "url": Astro.site
    }
  })} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-white text-gray-800 font-sans antialiased">
  <Header />

  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8">
      <a href="/" class="hover:text-brand-600 transition-colors">Home</a>
      <span>/</span>
      <a href="/blog" class="hover:text-brand-600 transition-colors">Reviews</a>
      <span>/</span>
      <span class="text-gray-600 truncate">{title}</span>
    </nav>

    <!-- Category badge -->
    <div class="mb-4">
      <span class="text-xs font-semibold text-brand-600 bg-brand-50 px-3 py-1 rounded-full uppercase tracking-wider">
        {category}
      </span>
    </div>

    <!-- Title -->
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight mb-4">{title}</h1>

    <!-- Meta row -->
    <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500 mb-8 pb-8 border-b border-gray-100">
      <span>By <strong class="text-gray-700">{author}</strong></span>
      <time datetime={pubDate.toISOString()}>Published {formattedPubDate}</time>
      {updatedDate && (
        <time datetime={updatedDate.toISOString()} class="italic">
          Updated {formattedUpdatedDate}
        </time>
      )}
    </div>

    <!-- Affiliate disclosure banner -->
    {affiliate_disclosure && (
      <div class="bg-amber-50 border border-amber-200 rounded-xl px-5 py-4 mb-8 text-sm text-amber-800">
        <strong>Affiliate Disclosure:</strong> This article contains affiliate links.
        If you purchase through our links, we may earn a small commission at no additional cost to you.
        Our reviews are always independent and honest.
      </div>
    )}

    <!-- Article body -->
    <article class="prose prose-gray max-w-none prose-headings:font-bold prose-a:text-brand-600 prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl">
      <slot />
    </article>

    <!-- Tags -->
    <div class="mt-12 pt-8 border-t border-gray-100">
      <p class="text-sm font-semibold text-gray-500 mb-3">Tagged:</p>
      <div class="flex flex-wrap gap-2">
        {tags.map(tag => (
          <span class="text-sm text-gray-500 bg-gray-50 border border-gray-200 px-3 py-1 rounded-lg">
            #{tag}
          </span>
        ))}
      </div>
    </div>

  </main>

  <Footer />
</body>
</html>
