---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = posts[0];
const rest = posts.slice(1);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BestPicks — Honest Product Reviews & Buying Guides</title>
  <meta name="description" content="Independent, research-backed reviews to help you buy smarter. We test and compare the best products so you don't have to." />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-gray-50 font-sans antialiased">
  <Header />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Hero -->
    <div class="text-center mb-14">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 mb-4 leading-tight">
        Buy Smarter.<br />
        <span class="text-brand-600">Research Faster.</span>
      </h1>
      <p class="text-lg text-gray-500 max-w-xl mx-auto">
        Independent reviews backed by real user data. We dig through specs, Reddit threads,
        and expert opinions so you can make confident decisions.
      </p>
    </div>

    <!-- Featured post -->
    {featured && (
      <a href={`/blog/${featured.slug}`} class="group block bg-white border border-gray-100 rounded-2xl p-8 hover:shadow-lg hover:border-brand-500/30 transition-all duration-200 mb-12">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xs font-semibold text-brand-600 bg-brand-50 px-2.5 py-0.5 rounded-full uppercase tracking-wide">
            {featured.data.category}
          </span>
          <span class="text-xs text-gray-400 bg-green-50 text-green-600 border border-green-200 px-2 py-0.5 rounded-full font-medium">
            Featured
          </span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900 group-hover:text-brand-600 transition-colors mb-3 leading-snug">
          {featured.data.title}
        </h2>
        <p class="text-gray-500 leading-relaxed">
          {featured.data.description}
        </p>
      </a>
    )}

    <!-- Latest articles grid -->
    {rest.length > 0 && (
      <section>
        <h2 class="text-xl font-bold text-gray-900 mb-6">Latest Reviews</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {rest.map(post => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.slug}
              category={post.data.category}
              tags={post.data.tags}
            />
          ))}
        </div>
      </section>
    )}

    {posts.length === 0 && (
      <div class="text-center py-20 text-gray-400">
        <p class="text-6xl mb-4">✍️</p>
        <p class="text-lg">No articles yet. Run the agent to generate your first review!</p>
      </div>
    )}

  </main>

  <Footer />
</body>
</html>
